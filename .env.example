# .env.example — plantilla. Copiá esto a un archivo .env local y completá con tus valores reales.
# NUNCA pongas valores reales en este archivo: .env.example SÍ se sube al repo, .env (real) no.
PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster0.xxxxx.mongodb.net/?appName=Cluster0
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
CORS_ORIGINS=https://metsim-frontend.vercel.app
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=onboarding@resend.dev
ADMIN_EMAIL=tu-email@ejemplo.com

CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# Autenticación del panel /admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esto-por-una-contraseña-fuerte

# Email (si usas nodemailer en vez de Resend)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-contraseña-de-aplicación

# URLs
FRONTEND_URL=https://tu-frontend.vercel.app
BACKEND_URL=https://metsim-backend.onrender.com
